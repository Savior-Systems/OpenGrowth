# =============================================================================
# OpenGrowth .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Private AI / Local Operations (NEVER commit)
# ---------------------------------------------------------------------------
.local-ai/
.local-ai/**

# ---------------------------------------------------------------------------
# Environment & Secrets
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Node.js / npm
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ---------------------------------------------------------------------------
# Build Outputs
# ---------------------------------------------------------------------------
dist/
build/
out/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Local Audit Outputs & Generated Reports
# ---------------------------------------------------------------------------
local-output/
local-reports/
opengrowth-report/
.test-output-temp/
*.local.html
*.local.json

# ---------------------------------------------------------------------------
# Coverage & Test Artifacts
# ---------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# ---------------------------------------------------------------------------
# OS Files
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project

# ---------------------------------------------------------------------------
# Local Database & Cache
# ---------------------------------------------------------------------------
.opengrowth-data/
*.sqlite
*.sqlite3
*.db
.cache/
.turbo/
.vercel/
.next/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
logs/
*.log

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.tgz
*.tar.gz
